# For running the frontend STANDALONE (outside Docker).
# In Docker, compose injects these from social-media-deploy/env/frontend-*.env instead.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8002/api   # point at a running backend (8001 FastAPI / 8002 Django)
INTERNAL_API_URL=http://localhost:8002
NEXT_PUBLIC_BACKEND_LABEL=Django REST Framework
